# ──────────────────────────────────────────────────────────────────────────
# Quantum Lab — credentials template
#
#   1.  cp .env.example .env
#   2.  fill in the tokens for the providers you want to use
#   3.  .env is gitignored — NEVER commit real tokens
#
# You need NONE of these to start: every provider has a free LOCAL simulator
# that runs offline. Tokens are only for running on REAL quantum hardware.
# ──────────────────────────────────────────────────────────────────────────

# ── IBM Quantum (FREE real hardware) ──────────────────────────────────────
# Sign up: https://quantum.cloud.ibm.com  →  create an API key + copy the
# instance CRN from your dashboard.
QISKIT_IBM_TOKEN=
QISKIT_IBM_INSTANCE=
QISKIT_IBM_CHANNEL=ibm_quantum_platform

# ── D-Wave Leap (FREE tier for annealing/optimization) ────────────────────
# Sign up: https://cloud.dwavesys.com/leap  →  copy your API token.
DWAVE_API_TOKEN=

# ── AWS Braket (⚠️  REAL DEVICES COST MONEY — no free hardware tier) ───────
# Only LocalSimulator() is free. Real QPUs/managed sims bill per task & shot.
# Uses standard AWS credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Google Cirq ───────────────────────────────────────────────────────────
# Local simulator needs nothing. Google's own QPUs are not openly available;
# third-party hardware (IonQ, AQT, …) via cirq plugins needs their own keys.
